rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.userType == 'admin';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAggregateOnlyUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['aggregatedRatings', 'reviewCount', 'ratingDistribution', 'reviewAggregation', 'updatedAt']);
    }

    function isGuideStatsOnlyUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['guideStats', 'updatedAt']);
    }

    function isVerifiedStudent() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.verificationStatus == 'approved' &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.verificationBadge != 'none';
    }

    function isHelpfulCountOnlyUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['helpfulCount', 'updatedAt']);
    }

    function isVerifiedStudentOfCollege(collegeId) {
      let user = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return isVerifiedStudent() && user.collegeId == collegeId;
    }

    function isQuestionAggregateUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['answerCount', 'mostHelpfulAnswerId', 'mostHelpfulScore', 'updatedAt']);
    }

    function isAnswerVoteCountUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['upvoteCount', 'downvoteCount', 'score', 'updatedAt']);
    }

    function isMostHelpfulAnswerUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['isMostHelpful', 'updatedAt']);
    }

    function isCommunityMessageAggregateUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['readBy', 'likeCount', 'likedBy', 'reportCount', 'status', 'moderationFlag', 'updatedAt']);
    }

    function isStudentPostAggregateUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['commentCount', 'pollOptions', 'likeCount', 'likedBy', 'reportCount', 'status', 'moderationFlag', 'updatedAt']);
    }

    function isQuestionModerationUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['reportCount', 'status', 'moderationFlag', 'updatedAt']);
    }

    function isVerifiedCompanyUser() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/company_accounts/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/company_accounts/$(request.auth.uid)).data.isVerified == true;
    }

    function companyAccountCompanyId() {
      return get(/databases/$(database)/documents/company_accounts/$(request.auth.uid)).data.companyId;
    }

    function isCallParticipant(sessionId) {
      let session = get(/databases/$(database)/documents/call_sessions/$(sessionId)).data;
      return isAuthenticated() &&
        (session.callerId == request.auth.uid || session.calleeId == request.auth.uid);
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update, delete: if isOwner(userId) || isAdmin() ||
        (isAuthenticated() && isGuideStatsOnlyUpdate());
    }

    match /colleges/{collegeId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAdmin() || (isAuthenticated() && isAggregateOnlyUpdate());
      allow delete: if isAdmin();
    }

    match /_meta/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        isVerifiedStudent() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.isVerifiedStudent == true;
      allow update: if isAdmin() ||
        (isAuthenticated() && resource.data.userId == request.auth.uid) ||
        (isAuthenticated() && isHelpfulCountOnlyUpdate());
      allow delete: if isAdmin() ||
        (isAuthenticated() && resource.data.userId == request.auth.uid);

      match /helpful/{voterId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && request.auth.uid == voterId;
      }
    }

    match /review_reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() &&
        request.resource.data.reporterId == request.auth.uid;
      allow update: if isAdmin();
    }

    match /call_sessions/{sessionId} {
      allow read: if isAuthenticated() &&
        (resource.data.callerId == request.auth.uid ||
         resource.data.calleeId == request.auth.uid);
      allow create: if isAuthenticated() &&
        request.resource.data.callerId == request.auth.uid;
      allow update: if isAuthenticated() &&
        (resource.data.callerId == request.auth.uid ||
         resource.data.calleeId == request.auth.uid);
    }

    match /interaction_ratings/{ratingId} {
      allow read: if isAuthenticated() &&
        (resource.data.raterId == request.auth.uid ||
         resource.data.rateeId == request.auth.uid ||
         isAdmin());
      allow create: if isAuthenticated() &&
        request.resource.data.raterId == request.auth.uid;
    }

    match /user_blocks/{blockId} {
      allow read: if isAuthenticated() &&
        resource.data.blockerId == request.auth.uid;
      allow create: if isAuthenticated() &&
        request.resource.data.blockerId == request.auth.uid;
    }

    match /user_reports/{reportId} {
      allow read: if isAdmin() ||
        (isAuthenticated() && resource.data.reporterId == request.auth.uid);
      allow create: if isAuthenticated() &&
        request.resource.data.reporterId == request.auth.uid;
      allow update: if isAdmin();
    }

    match /verification_requests/{requestId} {
      allow read: if isAdmin() ||
        (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
    }

    match /verification_document_hashes/{hashId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
    }

    match /placement_submissions/{submissionId} {
      allow read: if isAuthenticated() &&
        (isAdmin() ||
         resource.data.userId == request.auth.uid ||
         resource.data.status == 'approved');
      allow create: if isVerifiedStudent() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.isVerifiedStudent == true &&
        request.resource.data.status == 'pending_review';
      allow update: if isAdmin();
      allow delete: if isAdmin();

      match /private/{docId} {
        allow read: if isAdmin() ||
          (isAuthenticated() &&
           get(/databases/$(database)/documents/placement_submissions/$(submissionId)).data.userId == request.auth.uid);
        allow create: if isAuthenticated() &&
          get(/databases/$(database)/documents/placement_submissions/$(submissionId)).data.userId == request.auth.uid;
        allow update, delete: if isAdmin();
      }
    }

    match /community_conversations/{conversationId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /community_messages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.senderId == request.auth.uid;
      allow update: if isAuthenticated() &&
        (resource.data.senderId == request.auth.uid || isCommunityMessageAggregateUpdate());
      allow delete: if isAdmin();
    }

    match /community_reports/{reportId} {
      allow read: if isAdmin() ||
        (isAuthenticated() && resource.data.reporterId == request.auth.uid);
      allow create: if isAuthenticated() &&
        request.resource.data.reporterId == request.auth.uid;
      allow update: if isAdmin();
    }

    match /college_questions/{questionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.authorId == request.auth.uid;
      allow update: if isAdmin() ||
        (isAuthenticated() && resource.data.authorId == request.auth.uid) ||
        (isAuthenticated() && isQuestionAggregateUpdate()) ||
        (isAuthenticated() && isQuestionModerationUpdate());
      allow delete: if isAdmin();

      match /answers/{answerId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() &&
          isVerifiedStudentOfCollege(
            get(/databases/$(database)/documents/college_questions/$(questionId)).data.collegeId
          ) &&
          request.resource.data.authorId == request.auth.uid &&
          request.resource.data.isVerifiedStudent == true;
        allow update: if isAdmin() ||
          (isAuthenticated() && resource.data.authorId == request.auth.uid) ||
          (isAuthenticated() && isAnswerVoteCountUpdate()) ||
          (isAuthenticated() && isMostHelpfulAnswerUpdate());
        allow delete: if isAdmin();

        match /votes/{voterId} {
          allow read: if isAuthenticated();
          allow create, update: if isAuthenticated() && request.auth.uid == voterId;
          allow delete: if isAuthenticated() && request.auth.uid == voterId;
        }
      }
    }

    match /question_reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() &&
        request.resource.data.reporterId == request.auth.uid;
      allow update: if isAdmin();
    }

    match /answer_reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() &&
        request.resource.data.reporterId == request.auth.uid;
      allow update: if isAdmin();
    }

    match /scholarships/{scholarshipId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /entrance_exams/{examId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /cutoff_records/{cutoffId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /admission_predictions/{predictionId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
    }

    match /saved_scholarships/{docId} {
      allow read: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
    }

    match /internships/{internshipId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() ||
        (isVerifiedCompanyUser() &&
          request.resource.data.companyId == companyAccountCompanyId());
      allow update, delete: if isAdmin() ||
        (isVerifiedCompanyUser() &&
          resource.data.companyId == companyAccountCompanyId());
    }

    match /jobs/{jobId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() ||
        (isVerifiedCompanyUser() &&
          request.resource.data.companyId == companyAccountCompanyId());
      allow update, delete: if isAdmin() ||
        (isVerifiedCompanyUser() &&
          resource.data.companyId == companyAccountCompanyId());
    }

    match /companies/{companyId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /company_reviews/{reviewId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        isVerifiedStudent() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.isVerifiedStudent == true;
      allow update, delete: if isAdmin();
    }

    match /alumni_profiles/{alumniId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /saved_internships/{docId} {
      allow read: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
    }

    match /saved_jobs/{docId} {
      allow read: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
    }

    match /alumni_follows/{docId} {
      allow read: if isAuthenticated() &&
        resource.data.followerId == request.auth.uid;
      allow create: if isAuthenticated() &&
        request.resource.data.followerId == request.auth.uid;
      allow delete: if isAuthenticated() &&
        resource.data.followerId == request.auth.uid;
    }

    match /internship_applications/{applicationId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin() ||
          (isVerifiedCompanyUser() &&
            resource.data.companyId == companyAccountCompanyId()));
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() ||
        (isVerifiedCompanyUser() &&
          resource.data.companyId == companyAccountCompanyId() &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'updatedAt']));
      allow delete: if isAdmin();
    }

    match /job_applications/{applicationId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin() ||
          (isVerifiedCompanyUser() &&
            resource.data.companyId == companyAccountCompanyId()));
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() ||
        (isVerifiedCompanyUser() &&
          resource.data.companyId == companyAccountCompanyId() &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'updatedAt']));
      allow delete: if isAdmin();
    }

    match /student_resumes/{userId} {
      allow read: if isAuthenticated() &&
        (request.auth.uid == userId || isAdmin());
      allow create, update: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if isAuthenticated() && request.auth.uid == userId;
    }

    match /company_accounts/{userId} {
      allow read: if isAuthenticated() &&
        (request.auth.uid == userId || isAdmin());
      allow create, update, delete: if isAdmin();
    }

    match /campus_events/{eventId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /student_clubs/{clubId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /competitions/{competitionId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /student_communities/{communityId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /student_community_posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        isVerifiedStudent() &&
        request.resource.data.authorId == request.auth.uid &&
        request.resource.data.isVerifiedStudent == true;
      allow update: if isAdmin() ||
        (isAuthenticated() && resource.data.authorId == request.auth.uid) ||
        (isAuthenticated() && isStudentPostAggregateUpdate());
      allow delete: if isAdmin();

      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() &&
          isVerifiedStudent() &&
          request.resource.data.authorId == request.auth.uid &&
          request.resource.data.isVerifiedStudent == true;
        allow update: if isAdmin() ||
          (isAuthenticated() && resource.data.authorId == request.auth.uid);
        allow delete: if isAdmin();
      }
    }

    match /event_registrations/{docId} {
      allow read: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
    }

    match /saved_events/{docId} {
      allow read: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
    }

    match /club_join_requests/{docId} {
      allow read: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /student_community_post_reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() &&
        request.resource.data.reporterId == request.auth.uid;
      allow update: if isAdmin();
    }

    match /student_community_comment_reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() &&
        request.resource.data.reporterId == request.auth.uid;
      allow update: if isAdmin();
    }

    match /student_community_poll_votes/{voteId} {
      allow read: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
    }

    match /user_notifications/{notificationId} {
      allow read: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['isRead', 'updatedAt']);
      allow delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
    }

    match /notification_preferences/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow create, update: if isAuthenticated() && request.auth.uid == userId;
    }

    match /admission_calendar_events/{eventId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /saved_entrance_exams/{docId} {
      allow read: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
    }

    match /saved_questions/{docId} {
      allow read: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
    }

    match /college_analytics_events/{eventId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
