rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.userType in ['admin', 'super_admin'];
    }

    match /verification_documents/{userId}/{fileName} {
      allow read: if isAuthenticated() &&
        (request.auth.uid == userId || isAdmin());
      allow write: if isAuthenticated() &&
        request.auth.uid == userId &&
        request.resource.size < 10 * 1024 * 1024;
    }

    match /community_media/{conversationId}/{userId}/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() &&
        request.auth.uid == userId &&
        request.resource.size < 8 * 1024 * 1024;
    }

    match /profile_images/{userId}/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() &&
        request.auth.uid == userId &&
        request.resource.size < 5 * 1024 * 1024;
    }

    match /college_media/{collegeId}/{fileName} {
      allow read: if isAuthenticated();
      allow write: if (isAdmin() || isAuthenticated()) &&
        request.resource.size < 8 * 1024 * 1024;
    }

    match /college_media/{collegeId}/gallery/{fileName} {
      allow read: if isAuthenticated();
      allow write: if (isAdmin() || isAuthenticated()) &&
        request.resource.size < 8 * 1024 * 1024;
    }

    match /review_media/{userId}/{reviewId}/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() &&
        request.auth.uid == userId &&
        request.resource.size < 25 * 1024 * 1024;
    }

    match /placement_documents/{userId}/{fileName} {
      allow read: if isAuthenticated() &&
        (request.auth.uid == userId || isAdmin());
      allow write: if isAuthenticated() &&
        request.auth.uid == userId &&
        request.resource.size < 10 * 1024 * 1024;
    }

    match /resumes/{userId}/{fileName} {
      allow read: if isAuthenticated() &&
        (request.auth.uid == userId || isAdmin());
      allow write: if isAuthenticated() &&
        request.auth.uid == userId &&
        request.resource.size < 5 * 1024 * 1024;
    }

    match /college_claim_documents/{collegeId}/{userId}/{folder}/{fileName} {
      allow read: if isAuthenticated() &&
        (request.auth.uid == userId || isAdmin());
      allow write: if isAuthenticated() &&
        request.auth.uid == userId &&
        request.resource.size < 10 * 1024 * 1024;
    }

    match /faculty_documents/{userId}/{fileName} {
      allow read: if isAuthenticated() &&
        (request.auth.uid == userId || isAdmin());
      allow write: if isAuthenticated() &&
        request.auth.uid == userId &&
        request.resource.size < 10 * 1024 * 1024;
    }

    match /college_official_media/{collegeId}/{userId}/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() &&
        request.auth.uid == userId &&
        request.resource.size < 8 * 1024 * 1024;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
